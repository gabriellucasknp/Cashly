# Copie este arquivo para .env e preencha os valores antes de rodar `docker compose up`
# cp .env.example .env

# ─── Banco de dados (Docker local) ────────────────────────────────────────────
# Usuário do PostgreSQL local — usado apenas com docker compose (sem Supabase)
DB_USER=myuser

# Senha do PostgreSQL local — OBRIGATÓRIO, não use o valor de exemplo em produção
DB_PASSWORD=SenhaForte123!

# ─── Banco de dados (Supabase – produção) ─────────────────────────────────────
# Preencha estas variáveis ao fazer deploy apontando para o Supabase.
# O painel do Supabase → Project Settings → Database → Connection string (JDBC)
#
# Conexão direta (recomendada para JPA / HikariCP):
#   jdbc:postgresql://db.<PROJECT-REF>.supabase.co:5432/postgres
#
# Conexão via pooler (Transaction mode – porta 6543):
#   jdbc:postgresql://<PROJECT-REF>.pooler.supabase.com:6543/postgres
DB_URL=jdbc:postgresql://db.YOUR-PROJECT-REF.supabase.co:5432/postgres
# DB_USER já definido acima; para Supabase o usuário padrão é "postgres"
# DB_PASSWORD é a senha definida ao criar o projeto no Supabase

# ─── AI Agent ─────────────────────────────────────────────────────────────────
# Chave da API Google Gemini — OBRIGATÓRIO para classificação automática
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui

# URL do AI Agent (preenchida automaticamente pelo docker compose)
# Em produção, aponte para o endereço onde o ai-agent está hospedado
AI_AGENT_URL=http://ai-agent:8001

# ─── Reconhecimento de voz ─────────────────────────────────────────────────────
# O reconhecimento de voz usa a Web Speech API do navegador (sem custo adicional).
# Requer HTTPS em produção ou localhost em desenvolvimento.
# Navegadores suportados: Chrome 33+, Edge 79+, Safari 14.1+
