# Copie este arquivo para .env e preencha os valores antes de rodar `docker compose up`
# cp .env.example .env

# ─── Banco de dados ────────────────────────────────────────────────────────────
# Usuário do PostgreSQL (padrão: myuser)
DB_USER=myuser

# Senha do PostgreSQL — OBRIGATÓRIO, não use o valor de exemplo em produção
DB_PASSWORD=SenhaForte123!

# ─── AI Agent ─────────────────────────────────────────────────────────────────
# Chave da API Google Gemini — OBRIGATÓRIO para classificação automática
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui

# ─── Reconhecimento de voz ─────────────────────────────────────────────────────
# O reconhecimento de voz usa a Web Speech API do navegador (sem custo adicional).
# Requer HTTPS em produção ou localhost em desenvolvimento.
# Navegadores suportados: Chrome 33+, Edge 79+, Safari 14.1+
